# Vercel KV — copy from Vercel Dashboard → Storage → KV → .env.local
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# JWT secret — any random 32+ char string
JWT_SECRET=change-me-to-something-random-32chars

# Admin registration secret — needed to create first user
ADMIN_SECRET=my-admin-secret
